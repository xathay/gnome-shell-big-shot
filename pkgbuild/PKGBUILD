# Maintainer: Tales A. Mendonça <talesam@gmail.com>

pkgname=gnome-shell-big-shot
pkgdesc="Enhanced Screenshot & Screencast for GNOME Shell — annotation tools, audio recording, FPS/resolution control"
depends=('gnome-shell>=46' 'gstreamer' 'gst-plugins-base' 'gst-plugins-good' 'gst-plugins-bad' 'gst-plugin-va')
optdepends=(
    'gst-plugins-ugly: additional codecs'
)
makedepends=('gettext')
#conflicts=('')
#provides=('')
#replaces=('')
pkgver=$(date +%y.%m.%d)
pkgrel=$(date +%H%M)
arch=('any')
license=('MIT')
url="https://github.com/big-comm/${pkgname}"
source=("git+${url}.git")
md5sums=('SKIP')

# Automatically detect and use the correct install file
if [ -e "${pkgname}.install" ]; then
    install=${pkgname}.install
elif [ -e "pkgbuild.install" ]; then
    install=pkgbuild.install
fi

prepare() {
    cd "${srcdir}/${pkgname}"
    # Add any preparation steps here, if needed
    # For example: patch -p1 < "${srcdir}/patch-file.patch"
}

build() {
    cd "${srcdir}/${pkgname}"

    # Compile .po → .mo translations
    local _uuid="big-shot@bigcommunity.org"
    local _extdir="usr/share/gnome-shell/extensions/${_uuid}"
    local _podir="${_extdir}/po"
    local _localedir="${_extdir}/locale"

    for po_file in "${_podir}"/*.po; do
        [ -f "$po_file" ] || continue
        local lang=$(basename "$po_file" .po)
        local mo_dir="${_localedir}/${lang}/LC_MESSAGES"
        mkdir -p "$mo_dir"
        msgfmt "$po_file" -o "${mo_dir}/${_uuid}.mo"
    done
}

check() {
    cd "${srcdir}/${pkgname}"
    # Add check/test steps here, if needed
    # For example: make check
}

package() {
    cd "${srcdir}/${pkgname}"

    # Determine the correct source directory
    if [ -d "${pkgname}" ]; then
        srcdir="${srcdir}/${pkgname}/${pkgname}"
    else
        srcdir="${srcdir}/${pkgname}"
    fi

    # Install files
    local dirs=("usr" "etc" "opt")
    for dir in "${dirs[@]}"; do
        if [ -d "${srcdir}/${dir}" ]; then
            cp -a "${srcdir}/${dir}" "${pkgdir}/"
        fi
    done

    # Install license file if present
    if [ -f "LICENSE" ]; then
        install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    fi

    # Ensure patch script is executable
    if [ -f "${pkgdir}/usr/share/libalpm/scripts/gnome-shell-big-shot-screencast-fix.sh" ]; then
        chmod 755 "${pkgdir}/usr/share/libalpm/scripts/gnome-shell-big-shot-screencast-fix.sh"
    fi

    # Install documentation if present
    if [ -f "README.md" ]; then
        install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
    fi
}
